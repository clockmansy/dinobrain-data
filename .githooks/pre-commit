#!/usr/bin/env sh
set -eu

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File ".githooks/verify-public-data-guard.ps1" -Mode pre-commit
fi

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File ".githooks/verify-public-data-guard.ps1" -Mode pre-commit
fi

echo "DinoBrain data safety hook failed: PowerShell is required." >&2
exit 1
